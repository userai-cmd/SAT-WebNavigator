# OpenAI — обов'язково для LLM + RAG
OPENAI_API_KEY=sk-...

# Моделі (опційно)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG: скільки фрагментів передавати в LLM
RAG_TOP_K=5

# CORS для віджета на sat.ua
ALLOWED_ORIGINS=https://sat.ua,https://www.sat.ua

# Порт (Railway встановлює автоматично)
PORT=3000
